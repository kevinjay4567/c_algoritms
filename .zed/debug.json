// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug native binary",
    "build": {
      "command": "g++",
      "cwd": "${ZED_WORKTREE_ROOT}",
      "args": ["-g"]
    },
    "program": "${ZED_WORKTREE_ROOT}/booth",
    "request": "launch",
    "adapter": "GDB"
  }
]
